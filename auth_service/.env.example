DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/buslocator_auth

JWT_SECRET_KEY=generate_a_secure_random_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Base64 encoded JSON credential file
# To generate: cat firebase-adminsdk.json | base64 -w 0
FIREBASE_CREDENTIALS_BASE64=

# Razorpay Configuration (Paste your actual API credentials here)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret
RAZORPAY_WEBHOOK_SECRET=placeholder_webhook_secret

